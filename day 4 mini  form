<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Input types</title>
</head>
<body>
    <form>
        <label>Name:</label>
        <input type="text">
        <br><br>

        <label>Password:</label>
        <input type="password">
        <br><br>

        <label>Email:</label>
        <input type="email">
        <br><br>

        <label>Skills:</label>
        <p><input type="checkbox"> HTML</p>
        <p><input type="checkbox"> CSS</p>
        <p><input type="checkbox"> Bootstrap</p>
        <p><input type="checkbox"> JavaScript</p>
        <p><input type="checkbox"> Mysql</p>
        <br><br>

        <label>Course:</label>
        <input type="radio" name=" Course"> Java
        <input type="radio" name=" Course"> Python
        <input type="radio" name=" Course">AI
    </form>

</body>
</html>
